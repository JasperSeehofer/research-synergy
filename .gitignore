target/
.env
.env.*.local
data-*/

# Python prototype workspace (rebuild from prototypes/requirements-lock.txt)
prototypes/.venv/
**/__pycache__/

# Gardener sweep notes (local audit trail; not tracked)
.gardener-notes.md
.cartographer-notes.md
.commission-notes.md

# EXP-RS-21 embedding cache (regenerated by embed_score.py)
prototypes/data/embed_cache/

# RS-22 mining validation slices (throwaway)
prototypes/data/rs22_*_probe.json

# RS-22/RS-23 blind instrument INPUTS (deterministically regenerable via emit-inputs)
prototypes/data/rs22_in/
prototypes/data/rs23_in/
prototypes/data/rs23_in_mined/
# RS-22 detached mine run log (ephemeral; provenance is in rs22_mining_snapshot.json)
prototypes/rs22_mine_run.log
prototypes/data/rs22_probe_cache/

# RS-24 openbook inputs (regenerable via rs24_validate.py emit)
prototypes/data/rs24_in/
prototypes/rs24_mistral.log

# RS-25 cascade inputs (regenerable via rs25_cascade.py emit) + mistral logs
prototypes/data/rs25_in/
prototypes/rs25_mistral.log
prototypes/rs24_mistral*.log
prototypes/data/rs24_in/openbook_hard*/

# RS-26 discovery inputs (regenerable via rs26_discover.py extract)
prototypes/data/rs26_in/

# RS-27 external discovery inputs (regenerable)
prototypes/data/rs27_in/

# RS-28 calibration-control inputs (regenerable via rs28_control.py sample)
prototypes/data/rs28_in/

# RS-30 scaled-novelty inputs (regenerable via rs30_scale.py)
prototypes/data/rs30_in/

# RS-31 temporal-novelty inputs (regenerable via rs31_temporal.py)
prototypes/data/rs31_in/

# RS-32 method/object inputs (regenerable via rs32_asymmetric.py)
prototypes/data/rs32_in/
